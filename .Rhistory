Adoption <-
na.omit(Adoption)
seg_data2 <-
Adoption %>%
mutate(Q4n= 6-Q4, Q5n=6-Q4, Q6n=6-Q4, SUM=Q1+Q2+Q3+Q4n+Q5n+Q6n)
set.seed(123)         #    For reproducibility.
kmeans_result <-
kmeans(seg_data2, centers = 5, nstart = 25)
fviz_cluster(kmeans_result, data = seg_data2)
seg_data2 %>%
group_by(cluster) %>% summarise(mean_pts = mean(SUM))
seg_data2 %>%
group_by(cluster)
seg_data2
